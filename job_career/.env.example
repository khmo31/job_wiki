# Copy this file to .env and fill in your real values.

# Required for the fast model
GROQ_API_KEY=

# Required for the smart/evaluator model (set at least one)
NVIDIA_API_KEY=
OPENAI_API_KEY=

# Optional LLM/provider settings
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
CAREER_AGENT_FAST_MODEL=groq/llama-3.3-70b-versatile
CAREER_AGENT_SMART_MODEL=deepseek-ai/deepseek-v4-pro
CAREER_AGENT_FAST_TEMPERATURE=0.0
CAREER_AGENT_SMART_TEMPERATURE=0.2
CAREER_AGENT_MAX_TOKENS=128
CAREER_AGENT_FAST_TIMEOUT=20
CAREER_AGENT_SMART_TIMEOUT=45
CAREER_AGENT_FAST_MAX_RETRIES=0
CAREER_AGENT_SMART_MAX_RETRIES=0
CAREER_AGENT_MAX_CONCURRENCY=1
CAREER_AGENT_CONCURRENCY_WAIT=20
CAREER_AGENT_USE_SMART_EVALUATOR=0
CAREER_AGENT_ALLOW_MODEL_OVERRIDE=0
CAREER_AGENT_MAX_ITER=2
CAREER_AGENT_FINAL_MAX_ITER=4

# Optional tool/cache/server settings
ONTOLOGY_CHECK_CACHE_TTL=60
JOB_CAREER_PYTHON=
HOST=0.0.0.0
PORT=5000