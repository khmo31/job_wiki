# ============================================
# Job Wiki — 환경변수 예제
# ============================================
# 복사: cp .env.example .env (또는 GitHub Secrets에 등록)

# ── 필수 ──
# ALIO API 키 (공공데이터포털): 실제 데이터 수집 시 필요
ALIO_API_KEY="your_alio_api_key_here"

# ── LLM 분석 (택1, 우선순위 순) ──

# 1순위: OpenCode Go (deepseek-v4-flash, 권장)
#   - rate limit 없음, 저비용 ($0.14/M input)
OPENCODE_API_KEY="your_opencode_api_key_here"

# 2순위: Groq (llama-3.3-70b, 무료, 30 RPM 제한)
# GROQ_API_KEY="gsk_your_groq_key"

# 3순위: OpenAI
# OPENAI_API_KEY="sk-your_openai_key"

# 4순위: NVIDIA
# NVIDIA_API_KEY="nvapi-your_nvidia_key"

# ── 선택 ──
# LLM_PROVIDER=opencode-go        # 제공자 강제 지정
# LLM_EXTRACT_MODEL=deepseek-v4-flash  # 사용 모델
# OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
# NCS_FILTER_MODE=off             # NCS 필터 (off/soft/hard)
# ANALYSIS_MIN_CHARS_TO_CALL_LLM=300  # LLM 호출 최소 문자 수
